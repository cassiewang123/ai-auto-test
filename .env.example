# AIRETEST lightweight single-user configuration.
# Copy to .env. Generate private values for SECRET_KEY and
# SECRET_ENCRYPTION_KEY before keeping real data in the database.

APP_NAME=AI Test Platform
ENVIRONMENT=development
DEBUG=true

# SQLite is the default local database. Schema changes still use Alembic.
DATABASE_URL=sqlite:///./airetest-lite.db
DATABASE_ECHO=false
AUTO_CREATE_SCHEMA=false

# Execute queued jobs in a background thread inside the API process.
TASK_DISPATCH_MODE=local
TASK_FALLBACK_MODE=disabled
TASK_EAGER_IN_TESTS=true

SECRET_KEY=change-this-to-a-random-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=1440
# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_ENCRYPTION_KEY=B05PSgXbYda2gKpXbQ_2YvL5P4MzlSlRV03Kpd64NqU=
SECRET_ENCRYPTION_KEY_VERSION=v1

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
URL_ALLOW_PRIVATE=true
URL_ALLOWED_DOMAINS=
URL_BLOCKED_DOMAINS=

OPENAI_API_KEY=
LLM_MODEL=gpt-4
LLM_BASE_URL=

ALLOW_SYNC_EXECUTION=true
SCRIPT_EXECUTION_TIMEOUT=30
ARTIFACT_ROOT=.uploads
ALLOW_DIRECT_FILE_PATHS=false
