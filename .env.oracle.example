# Optional Oracle/Redis/Celery Docker configuration.
# Copy to .env.oracle and replace all credentials.
APP_NAME=AI Test Platform
ENVIRONMENT=development
DEBUG=true

DATABASE_URL=oracle+oracledb://airetest:airetest_dev@localhost:1521/?service_name=FREEPDB1
COMPOSE_DATABASE_URL=oracle+oracledb://airetest:airetest_dev@oracle:1521/?service_name=FREEPDB1
ORACLE_PASSWORD=oracle_dev
ORACLE_APP_USER=airetest
ORACLE_APP_PASSWORD=airetest_dev
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_RECYCLE_SECONDS=1800
AUTO_CREATE_SCHEMA=false

REDIS_URL=redis://localhost:6379/0
TASK_DISPATCH_MODE=celery
TASK_FALLBACK_MODE=disabled
TASK_EAGER_IN_TESTS=true
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_API_QUEUE=airetest.api
CELERY_UI_QUEUE=airetest.ui
CELERY_PERFORMANCE_QUEUE=airetest.performance
CELERY_TASK_ACKS_LATE=true
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_TERMINATE_SIGNAL=SIGTERM

SECRET_KEY=change-this-to-a-random-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=1440
SECRET_ENCRYPTION_KEY=B05PSgXbYda2gKpXbQ_2YvL5P4MzlSlRV03Kpd64NqU=
SECRET_ENCRYPTION_KEY_VERSION=v1

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
URL_ALLOW_PRIVATE=true
URL_ALLOWED_DOMAINS=
URL_BLOCKED_DOMAINS=

MINIO_ROOT_USER=airetest
MINIO_ROOT_PASSWORD=airetest_dev

OPENAI_API_KEY=
LLM_MODEL=gpt-4
LLM_BASE_URL=

ALLOW_SYNC_EXECUTION=true
SCRIPT_EXECUTION_TIMEOUT=30
ARTIFACT_ROOT=uploads
ALLOW_DIRECT_FILE_PATHS=false
